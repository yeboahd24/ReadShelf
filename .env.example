PORT=8080
DATABASE_URL=postgres://user:password@localhost:5432/readshelf?sslmode=disable
JWT_SECRET=change-me-to-a-random-secret

# Storage: "cloudinary" or "r2"
STORAGE_PROVIDER=cloudinary

# Cloudinary (free tier)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Cloudflare R2 (if using r2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=readshelf-pdfs

# Embedder: "nomic" or "claude"
EMBEDDER_PROVIDER=nomic

# HuggingFace API key (for embeddings free tier)
HUGGINGFACE_API_KEY=

# AI recall provider: "groq" or "claude"
AI_PROVIDER=groq

# Groq API key (free tier — https://console.groq.com)
GROQ_API_KEY=

# Claude API key (optional, for paid embeddings + recall)
CLAUDE_API_KEY=
